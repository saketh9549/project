# Video Chapter Indexer Configuration

# Google Gemini API Key (required for topic-wise semantic chunking)
GEMINI_API_KEY=your_gemini_api_key_here

# SQLite database file path (directories will be created automatically)
DB_PATH=data/indexer.db

# Model name for Gemini API (e.g. gemini-3.1-flash-lite, gemini-3.5-flash)
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: Path to custom ffmpeg executable if it's not in your system PATH
# FFMPEG_PATH=C:\path\to\ffmpeg.exe
